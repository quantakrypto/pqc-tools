# frozen_string_literal: true

source "https://rubygems.org"

ruby "3.3.0"

# Web / API layer
gem "rails", "~> 7.1"
gem "puma", ">= 6.4"
gem "pg", "~> 1.5"

# --- Cryptography / auth stack ---
gem "jwt", "~> 2.8"            # RS256 / ES256 / EdDSA token signing
gem "ed25519", "~> 1.3"       # Ed25519 signatures for the audit trail
gem "rbnacl", "~> 7.1"        # libsodium: Curve25519 (X25519) boxes
gem "net-ssh", "~> 7.2"       # remote deploy over SSH

group :development, :test do
  gem "rspec-rails", "~> 6.1"
  gem "rubocop", require: false
end
